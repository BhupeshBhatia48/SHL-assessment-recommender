# Copy this file to .env (or set these as real environment variables on
# your deployment platform) and fill in the key for whichever provider you
# choose. Only one provider needs a key -- set LLM_PROVIDER to match it.

# "gemini" or "groq"
LLM_PROVIDER=gemini

# Required if LLM_PROVIDER=gemini. Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Required if LLM_PROVIDER=groq. Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional tuning (defaults shown)
LLM_TIMEOUT_SECONDS=12
RETRIEVAL_TOP_K=18
